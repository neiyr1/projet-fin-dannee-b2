@page
@{ Layout = "_Layout"; ViewData["Title"] = "Login"; }
<div class="card">
  <div class="brand">
    <div class="logo"><img src="../wwwroot/images/Logo_1_mini.svg" alt="CoWork Manager"></div>
    <div>
      <div style="font-weight:700;">CoWork Manager</div>
      <div class="muted" style="font-size:13px;">Manage spaces and bookings</div>
    </div>
  </div>

  <form id="loginForm">
    <label>Username
      <input name="username" required autocomplete="username">
    </label>
    <label>Password
      <input name="password" type="password" required autocomplete="current-password">
    </label>
    <button type="submit">Sign in</button>
  </form>

  <p id="msg" class="muted center" style="margin-top:12px"></p>
</div>
