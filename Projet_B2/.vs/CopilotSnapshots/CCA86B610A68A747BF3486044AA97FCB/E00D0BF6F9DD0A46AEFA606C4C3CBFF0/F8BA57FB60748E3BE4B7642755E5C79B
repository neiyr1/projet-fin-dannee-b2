@page
@{ Layout = "_Layout"; ViewData["Title"] = "Spaces Map"; }
<div class="d-flex justify-content-between align-items-center mb-3">
  <div class="d-flex align-items-center gap-3">
    <img src="/images/Logo_1_mini.svg" alt="Logo" style="height:36px" />
    <h1 class="h4 mb-0">Spaces Map</h1>
  </div>
  <div class="d-flex gap-2">
    <input id="search" placeholder="Search spaces" class="form-control form-control-sm" style="min-width:200px" />
    <button id="refresh" class="btn btn-sm btn-outline-secondary">Refresh</button>
  </div>
  <div id="count" class="text-muted small"></div>
</div>

<div class="row">
  <aside class="col-md-3">
    <div class="card">
      <div class="card-body">
        <h6 class="text-muted">Spaces</h6>
        <ul id="spaceList" class="list-group"></ul>
      </div>
    </div>
  </aside>

  <section class="col-md-9">
    <div id="mapContainer" class="card mb-2" style="min-height:300px" aria-label="Co-working spaces map"></div>
    <div id="detailPanel" class="card card-body text-muted small">Hover a space to see details</div>
  </section>
</div>

<div class="mt-3">
  <span class="badge bg-success">Available</span>
  <span class="badge bg-secondary">Occupied</span>
</div>

<p class="mt-3"><a href="/Spaces">Back to list</a></p>
