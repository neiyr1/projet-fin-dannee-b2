:root{
  --bg:#f4f6fb;
  --card:#ffffff;
  --muted:#64748b;
  --accent:#2563eb;
  --accent-strong:#1e40af;
  --danger:#ef4444;
}
*{box-sizing:border-box}
body {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
  margin: 0;
  color: #0f172a;
  background: linear-gradient(180deg,var(--bg), #eef2ff 120px);
  -webkit-font-smoothing:antialiased;
}
header.site-header{display:none}
.site-wrap{max-width:1100px;margin:20px auto;padding:16px}
main{background:var(--card);border-radius:12px;padding:28px;box-shadow:0 10px 30px rgba(2,6,23,0.06);} 
h1{margin-top:0;font-size:26px}
p{color:var(--muted);line-height:1.6}
.nav{display:flex;align-items:center;justify-content:space-between;gap:12px}
.brand{display:flex;align-items:center;gap:12px}
.brand .logo{width:48px;height:48px;border-radius:10px;background:linear-gradient(135deg,#6ee7b7,#3b82f6);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700}
.nav-links{display:flex;gap:12px;align-items:center}
.nav-links a{color:var(--accent-strong);text-decoration:none;padding:8px 12px;border-radius:8px;font-weight:600}
.nav-links a:hover{background:rgba(37,99,235,0.08)}
.muted{color:var(--muted);font-size:14px}
.center{text-align:center}
.logo img{width:36px;height:36px}

/* map specific tweaks */
.map-container{width:100%;height:320px;background:linear-gradient(180deg,#fff,#f8fafc);border-radius:6px}
.detail-panel{min-height:48px}
.space-list .list-group-item{cursor:pointer}
